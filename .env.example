# OpenRouter (OpenAI-compatible SDK) — free-tier model access for Day 2 baseline
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_chosen_free_model_id_here

# HuggingFace Inference API — alternate free-tier provider (used for Day 1-3 in this project)
# HF's router requires an explicit inference provider per model (see scripts/verify_hf.py
# for how HF_PROVIDER was discovered — HF doesn't auto-select one for you).
HF_API_KEY=your_hf_api_key_here
HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct
HF_PROVIDER=featherless-ai

# LangSmith tracing (Day 3)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=invoice-copilot

# Weights & Biases (Day 4-5 fine-tuning)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=invoice-copilot-finetune
