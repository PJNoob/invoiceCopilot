{
  "target_effective_count": 500,
  "group_fields": ["metadata.domain", "metadata.difficulty", "metadata.intent"],
  "group_minimums": {
    "metadata.intent=classify_intent": 80,
    "metadata.intent=classify_sentiment": 80,
    "metadata.intent=classify_topic": 80,
    "metadata.intent=classify_difficulty": 80,
    "metadata.domain=nlp": 60,
    "metadata.domain=content_moderation": 60,
    "metadata.domain=medical_triage": 50,
    "metadata.domain=support_tickets": 60,
    "metadata.difficulty=easy": 100,
    "metadata.difficulty=medium": 250,
    "metadata.difficulty=hard": 150
  },
  "quality_filter": {
    "task_relative_minimums": true,
    "anti_trope": true
  },
  "syntax_checks": {
    "python": false,
    "json": true
  },
  "code_quality": {
    "enabled": false,
    "python_ast": false,
    "json": true,
    "javascript_balance": false,
    "shell_balance": false,
    "sql_balance": false
  },
  "dpo_audit": {
    "enabled": false,
    "require_delta": false,
    "min_chosen_chars": 0,
    "min_rejected_chars": 0,
    "max_length_ratio": 3.0
  },
  "benchmark_contamination": {
    "enabled": true,
    "blocking": true
  },
  "grounding": {
    "require_evidence_ids": false,
    "minimum_response_evidence_overlap": 0.0
  },
  "provenance": {
    "field": "metadata.source_origin",
    "real_world_values": ["real_world"],
    "minimum_real_world_share": 0.3,
    "reference_fields": ["metadata.reference_urls", "source_uri"],
    "blocking": false
  }
}
