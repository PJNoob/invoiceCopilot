{
  "target_effective_count": 1000,
  "group_fields": ["metadata.intent", "metadata.difficulty"],
  "group_minimums": {
    "metadata.intent=dpo_factual_precision": 180,
    "metadata.intent=dpo_format_compliance": 180,
    "metadata.intent=dpo_reasoning_depth": 200,
    "metadata.intent=dpo_safety_boundary": 100,
    "metadata.intent=dpo_instruction_following": 200,
    "metadata.difficulty=easy": 200,
    "metadata.difficulty=medium": 500,
    "metadata.difficulty=hard": 300
  },
  "quality_filter": {
    "task_relative_minimums": true,
    "anti_trope": true
  },
  "syntax_checks": {
    "python": false,
    "json": true
  },
  "code_quality": {
    "enabled": false,
    "python_ast": false,
    "json": true,
    "javascript_balance": false,
    "shell_balance": false,
    "sql_balance": false
  },
  "dpo_audit": {
    "enabled": true,
    "require_delta": true,
    "min_chosen_chars": 80,
    "min_rejected_chars": 40,
    "max_length_ratio": 4.0
  },
  "benchmark_contamination": {
    "enabled": true,
    "blocking": true
  },
  "grounding": {
    "require_evidence_ids": false,
    "minimum_response_evidence_overlap": 0.0
  },
  "provenance": {
    "field": "metadata.source_origin",
    "real_world_values": ["real_world"],
    "minimum_real_world_share": 0.3,
    "reference_fields": ["metadata.reference_urls", "source_uri"],
    "blocking": false
  }
}
